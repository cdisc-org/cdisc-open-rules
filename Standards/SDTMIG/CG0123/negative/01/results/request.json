    "sensitivity": "Record",
    "severity": "error",
    "description": "Trigger error if length of ACTARMCD is greater than 20 characters",
    "authority": {
      "Organization": "CDISC"
    },
    "standards": [
      {
        "Name": "SDTMIG",
        "Version": "3.4"
      }
    ],
    "classes": {
      "Include": [
        "Special-Purpose"
      ]
    },
    "domains": {
      "Include": [
        "DM"
      ]
    },
    "rule_type": "Variable Length",
    "conditions": {
      "all": [
        {
          "name": "get_dataset",
          "operator": "longer_than",
          "value": {
            "target": "ACTARMCD",
            "comparator": 20
          }
        }
      ]
    },
    "output_variables": [
      "ACTARMCD"
    ],
    "actions": [
      {
        "name": "generate_dataset_error_objects",
        "params": {
          "message": "Length of ACTARMCD is greater than 20 characters"
        }
      }
    ]
  },
