{
    "rule": {
      "_links": {},
      "core_id": "CDISC.SDTMIG.CG0060",
      "reference": [
        {
          "Origin": "SDTM and SDTMIG Conformance Rules",
          "Rule Identifier": {
            "Id": "CG0060",
            "Version": "1"
          },
          "Version": "2.0"
        }
      ],
      "sensitivity": "Dataset",
      "severity": "error",
      "description": "Raise an error when --STTPT is present in dataset and --STRTPT is not present in dataset.",
      "authority": {
        "Organization": "CDISC"
      },
      "standards": [
        {
          "Name": "SDTMIG",
          "Version": "3.4"
        }
      ],
      "classes": {
        "Include": [
          "All"
        ]
      },
      "domains": {
        "Include": [
          "All"
        ]
      },
      "rule_type": "Variable Presence",
      "conditions": {
        "all": [
          {
            "name": "get_dataset",
            "operator": "exists",
            "value": {
              "target": "--STTPT"
            }
          },
          {
            "name": "get_dataset",
            "operator": "not_exists",
            "value": {
              "target": "--STRTPT"
            }
          }
        ]
      },
      "output_variables": [
        "--STTPT"
      ],
      "actions": [
        {
          "name": "generate_dataset_error_objects",
          "params": {
            "message": "--STTPT is present in dataset, but --STRTPT is not present in dataset."
          }
        }
      ]
    },
