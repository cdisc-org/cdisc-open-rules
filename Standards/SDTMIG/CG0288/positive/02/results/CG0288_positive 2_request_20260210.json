        "Check": {
            "all": [
                {
                    "name": "TSVCDREF",
                    "operator": "prefix_equal_to",
                    "prefix": 5,
                    "value": "CDISC"
                },
                {
                    "name": "$VALID_TERM_CODES",
                    "operator": "non_empty"
                },
                {
                    "name": "TSVALCD",
                    "operator": "is_not_contained_by",
                    "value": "$VALID_TERM_CODES"
                }
            ]
        },
        "Core": {
            "Id": "CDISC.SDTMIG.CG0288",
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "Raise an error when TSVCDREF ='CDISC' and TSVALCD is not a valid code in the version identified in TSVCDVER.",
        "Executability": "Fully Executable",
        "Operations": [
            {
                "ct_attribute": "Term CCODE",
                "id": "$VALID_TERM_CODES",
                "name": "TSVCDREF",
                "operator": "get_codelist_attributes",
                "version": "TSVCDVER"
            }
        ],
        "Outcome": {
            "Message": "TSVALCD is not a valid code in the CDISC CT version identified in TSVCDVER.",
            "Output_Variables": [
                "TSVALCD",
                "TSPARMCD",
                "TSVCDVER"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "TRIAL DESIGN"
                ]
            },
            "Domains": {
                "Include": [
                    "TS"
                ]
            }
        },
        "Sensitivity": "Record",
        "Rule_Type": "Record Data"
    },
