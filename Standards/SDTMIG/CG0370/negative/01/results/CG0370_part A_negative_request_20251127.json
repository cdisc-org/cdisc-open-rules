        "Check": {
            "all": [
                {
                    "name": "RDOMAIN",
                    "operator": "exists"
                },
                {
                    "name": "IDVAR",
                    "operator": "non_empty"
                },
                {
                    "name": "IDVAR",
                    "operator": "is_not_contained_by",
                    "value": "$rdomain_variables"
                }
            ]
        },
        "Core": {
            "Id": "CORE-000712",
            "Status": "Published",
            "Version": "1"
        },
        "Description": "Part A - Raise and error when IDVAR in SUPP-- is not populated with a valid variable from the dataset referenced in RDOMAIN.",
        "Executability": "Fully Executable",
        "Operations": [
            {
                "domain": "SUPP--",
                "id": "$rdomain_variables",
                "name": "IDVAR",
                "operator": "distinct",
                "value_is_reference": true
            }
        ],
        "Outcome": {
            "Message": "Value for IDVAR in SUPP-- does not represent a variable present in the dataset referenced in RDOMAIN.",
            "Output_Variables": [
                "IDVAR"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "RELATIONSHIP"
                ]
            },
            "Domains": {
                "Include": [
                    "SUPP--"
                ]
            },
            "Use_Case": "INDH, PROD"
        },
        "Sensitivity": "Record",
        "Match_Datasets": [
            {
                "Child": true,
                "Keys": [
                    "USUBJID",
                    "IDVAR",
                    "IDVARVAL"
                ],
                "Name": "SUPP--"
            }
        ],
        "Rule_Type": "Record Data"
    },
