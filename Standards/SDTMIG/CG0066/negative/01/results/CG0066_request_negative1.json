        "Organization": "CDISC",
        "Standards": [
          {
            "Name": "SDTMIG",
            "Version": "3.2",
            "References": [
              {
                "Origin": "SDTM and SDTMIG Conformance Rules",
                "Version": "2.0",
                "Citations": [
                  {
                    "Document": "IG v3.2",
                    "Item": "Assumption 3d",
                    "Section": "6.2",
                    "Cited_Guidance": "d. When DSCAT='PROTOCOL MILESTONE', DSTERM and DSDECOD will contain the same value drawn from the sponsor's controlled terminology."
                  }
                ],
                "Rule_Identifier": {
                  "Id": "CG0066",
                  "Version": "1"
                }
              }
            ]
          }
        ]
      }
    ],
    "Core": {
      "Id": "CDISC.SDTMIG.CG0066",
      "Version": "1",
      "Status": "Draft"
    },
    "Description": "When DSCAT equals PROTOCOL MILESTONE, then DSTERM should be equal to DSDECOD",
    "Outcome": {
      "Message": "DSCAT equals PROTOCOL MILESTONE but DSTERM is not equal to DSDECOD",
      "Output_Variables": [
        "DSTERM",
        "DSDECOD"
      ]
    },
    "Sensitivity": "Record",
    "Scope": {
      "Classes": {
        "Include": [
          "EVENTS"
        ]
      },
      "Domains": {
        "Include": [
          "DS"
        ]
      }
    },
    "Executability": "Fully Executable",
    "Check": {
      "all": [
        {
          "name": "DSCAT",
          "operator": "equal_to",
          "value": "PROTOCOL MILESTONE",
          "value_is_literal": true
        },
        {
          "name": "DSTERM",
          "operator": "not_equal_to",
          "value": "DSDECOD"
        }
      ]
    },
    "Rule_Type": "Record Data"
  },
