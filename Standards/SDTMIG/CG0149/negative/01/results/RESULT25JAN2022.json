    "sensitivity": "Record",
    "severity": "error",
    "description": "Verify that the length of value in SETCD variable is <= 8",
    "authority": {
      "Organization": "CDISC"
    },
    "standards": [
      {
        "Name": "SDTMIG",
        "Version": "3.4"
      }
