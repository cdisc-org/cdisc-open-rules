    },
    "domains": {
      "Include": [
        "DM",
        "TX"
      ]
    },
    "rule_type": "Variable Length",
    "conditions": {
      "all": [
        {
          "name": "get_dataset",
          "operator": "matches_regex",
          "value": {
            "target": "SETCD",
            "comparator": "^(.){9,}$"
