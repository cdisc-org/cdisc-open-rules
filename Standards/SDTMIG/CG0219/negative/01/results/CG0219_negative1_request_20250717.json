    "rule": {
        "Authorities": [
            {
                "Organization": "CDISC",
                "Standards": [
                    {
                        "Name": "SDTMIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "IG v3.4",
                                        "Section": "4.4",
                                        "Cited_Guidance": "Timing variables (SDTM Table 2.2.5) are an essential component of all SDTM subject-level domain datasets. In general, all domains based on the three general observation classes should have at least one Timing variable. In the Events or Interventions general observation class, this could be the start date of the event or intervention. In the Findings observation class, where data are usually collected at multiple visits, at least one Timing variable must be used."
                                    }
                                ],
                                "Origin": "SDTM and SDTMIG Conformance Rules",
                                "Version": "2.0",
                                "Rule_Identifier": {
                                    "Id": "CG0219",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Version": "3.4"
                    },
