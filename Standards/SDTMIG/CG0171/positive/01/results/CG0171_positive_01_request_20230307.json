{
  "rule": {
    "Check": {
      "all": [
        {
          "name": "SSSTRESC",
          "operator": "equal_to",
          "value": "DEAD",
          "value_is_literal": true
        },
        {
          "name": "SSDTC",
          "operator": "date_less_than",
          "value": "DTHDTC"
        }
      ]
    },
    "Core": {
      "Id": "CDISC.SDTMIG.CG0171",
      "Version": "1",
      "Status": "Draft"
    },
    "Description": "Raise an error when SSSTRESC = 'DEAD' and SSDTC < DM.DTHDTC.",
    "Outcome": {
      "Message": "SSSTRESC = 'DEAD', but SSDTC < DM.DTHDTC.",
      "Output_Variables": [
        "SSSTRESC",
        "SSDTC",
        "DTHDTC"
      ]
    },
    "Sensitivity": "Record",
    "Executability": "Fully Executable",
    "Authorities": [
      {
        "Organization": "CDISC",
        "Standards": [
          {
            "Name": "SDTMIG",
            "Version": "3.4",
            "References": [
              {
                "Origin": "SDTM and SDTMIG Conformance Rules",
                "Version": "2.0",
                "Citations": [
                  {
                    "Document": "IG v3.4",
                    "Item": "Assumption 1",
                    "Section": "6.3.11",
                    "Cited_Guidance": "Subject Status does not contain details about the circumstances of a subject's status. The response to the status assessment may trigger collection of additional details, but those details are to be stored in appropriate separate domains. For example, if a subject's survival status is \"DEAD\", the date of death must be stored in DM and within a final disposition record in DS. Only the status collection date, the status question, and the status response are stored in SS."
                  }
                ],
                "Rule_Identifier": {
                  "Id": "CG0171",
                  "Version": "1"
                }
              }
            ]
          },
          {
            "Name": "SDTMIG",
            "Version": "3.3",
            "References": [
              {
                "Origin": "SDTM and SDTMIG Conformance Rules",
                "Version": "2.0",
                "Citations": [
                  {
                    "Document": "IG v3.3",
                    "Item": "Assumption 1",
                    "Section": "6.3.15",
                    "Cited_Guidance": "Subject Status does not contain details about the circumstances of a subject's status. The response to the status assessment may trigger collection of additional details but those details are to be stored in appropriate separate domains. For example, if a subject's Survival Status is \"DEAD\", the date of death must be stored in DM and within a final disposition record in DS. Only the status collection date, the status question and the status response are stored in SS."
                  }
                ],
                "Rule_Identifier": {
                  "Id": "CG0171",
                  "Version": "1"
                }
              }
            ]
          },
          {
            "Name": "SDTMIG",
            "Version": "3.2",
            "References": [
              {
                "Origin": "SDTM and SDTMIG Conformance Rules",
                "Version": "2.0",
                "Citations": [
                  {
                    "Document": "IG v3.2",
                    "Item": "Assumption 2",
                    "Section": "6.3.",
                    "Cited_Guidance": "Subject Status does not contain details about the circumstances of a subject's status. The response to the status assessment may trigger collection of additional details but those details are to be stored in appropriate separate domains. For example, if a subject's Survival Status is \"DEAD\", the date of death must be stored in DM and within a final disposition record in DS. Only the status collection date, the status question and the status response are stored in SS."
                  }
                ],
                "Rule_Identifier": {
                  "Id": "CG0171",
                  "Version": "1"
                }
              }
            ]
          }
        ]
      }
    ],
