        },
        "Core": {
            "Id": "CORE-000017",
            "Status": "Published",
            "Version": "1"
        },
        "Description": "Raise an error when RDOMAIN is null when IDVARVAL is not null.",
        "Executability": "Fully Executable",
        "Outcome": {
