          "Name": "SDTMIG",
          "Version": "3.4"
        },
        {
          "Name": "SDTMIG",
          "Version": "3.3"
        },
        {
          "Name": "SDTMIG",
          "Version": "3.2"
        }
      ]
    },
    "Sensitivity": "Record",
    "Severity": "Error",
    "Rule_Type": "Consistency"
  },
