    "rule": {
        "Authorities": [
            {
                "Organization": "CDISC",
                "Standards": [
                    {
                        "Name": "SDTMIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "IG v3.4",
                                        "Item": "Assumption 11",
                                        "Section": "5.5",
                                        "Cited_Guidance": "If TAETORD and/or EPOCH are added, then the values must be those at the start of the visit."
                                    }
                                ],
                                "Origin": "SDTM and SDTMIG Conformance Rules",
                                "Version": "2.0",
                                "Rule_Identifier": {
                                    "Id": "CG0217",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Version": "3.4"
                    },
                    {
                        "Name": "SDTMIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "IG v3.2",
                                        "Item": "Assumption 11",
                                        "Section": "5 SV",
                                        "Cited_Guidance": "If TAETORD and/or EPOCH are added, then the values must be those at the start of the visit.It would be inappropriate to add the variables that support time points (--TPT, --TPTNUM, --ELTM, --TPTREF, and --RFTDTC), since the topic of this dataset is visits."
                                    }
                                ],
                                "Origin": "SDTM and SDTMIG Conformance Rules",
                                "Version": "2.0",
                                "Rule_Identifier": {
                                    "Id": "CG0217",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Version": "3.2"
                    },
                    {
                        "Name": "SDTMIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "IG v3.3",
                                        "Item": "Assumption 11",
                                        "Section": "5.5",
                                        "Cited_Guidance": "If TAETORD and/or EPOCH are added, then the values must be those at the start of the visit.It would be inappropriate to add the variables that support time points (--TPT, --TPTNUM, --ELTM, --TPTREF, and --RFTDTC), since the topic of this dataset is visits."
                                    }
                                ],
                                "Origin": "SDTM and SDTMIG Conformance Rules",
                                "Version": "2.0",
                                "Rule_Identifier": {
                                    "Id": "CG0217",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Version": "3.3"
                    },
                    {
                        "Name": "TIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "TIG 1.0",
                                        "Item": "Assumption 11",
                                        "Section": "2.8.10.25",
                                        "Cited_Guidance": "If TAETORD and/or EPOCH are added, then the values must be those at the start of the visit."
                                    }
                                ],
                                "Origin": "TIG Conformance Rules",
                                "Version": "1.0",
