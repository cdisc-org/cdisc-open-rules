        "Check": {
            "all": [
                {
                    "name": "TAETORD",
                    "operator": "exists"
                },
                {
                    "name": "SVSTDTC",
                    "operator": "date_greater_than_or_equal_to",
                    "value": "SESTDTC"
                },
                {
                    "name": "SVSTDTC",
                    "operator": "date_less_than_or_equal_to",
                    "value": "SEENDTC"
                },
                {
                    "name": "TAETORD",
                    "operator": "not_equal_to",
                    "value": "SE.TAETORD"
                }
            ]
        },
        "Core": {
            "Id": "CDISC.SDTMIG.CG0217",
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "Raise an error when variable TAETORD values don't match between Subject Visits (SV) and Subject Elements (SE) datasets.",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "TAETORD values don't match between Subject Visits (SV) and Subject Elements (SE) datasets.",
            "Output_Variables": [
                "SESTDTC",
                "SEENDTC",
                "SVSTDTC",
                "TAETORD",
                "SE.TAETORD"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "SPECIAL PURPOSE"
                ]
            },
            "Domains": {
                "Include": [
                    "SV"
                ]
            },
            "Use_Case": "INDH"
        },
        "Sensitivity": "Record",
        "Match_Datasets": [
            {
                "Keys": [
                    "USUBJID"
                ],
                "Name": "SE"
            }
        ],
        "Rule_Type": "Record Data"
    },
