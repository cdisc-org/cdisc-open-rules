{
    "rule": {
        "Authorities": [
            {
                "Organization": "CDISC",
                "Standards": [
                    {
                        "Name": "SDTMIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "IG v3.4",
                                        "Section": "4.2.7.4",
                                        "Cited_Guidance": "When findings are collected about an event or intervention, and the name of the event or intervention is collected in an \"Other, specify\" CRF field, the value in --OBJ variable depends on whether the FA record has a parent record and whether the \"Other, specify\" value was coded."
                                    }
                                ],
                                "Origin": "SDTM and SDTMIG Conformance Rules",
                                "Version": "2.0",
                                "Rule_Identifier": {
                                    "Id": "CG0602",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Version": "3.4"
                    },
                    {
                        "Name": "TIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "TIG 1.0",
                                        "Section": "2.8.7.4",
                                        "Cited_Guidance": "When findings are collected about an event or intervention, and the name of the event or intervention is collected in an \"Other, specify\" CRF field, the value in --OBJ variable depends on whether the FA record has a parent record and whether the \"Other, specify\" value was coded."
                                    }
                                ],
                                "Origin": "TIG Conformance Rules",
                                "Version": "1.0",
                                "Rule_Identifier": {
                                    "Id": "TIG0656",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Substandard": "SDTM",
                        "Version": "1.0"
                    }
                ]
            }
        ],
        "Check": {
            "all": [
                {
                    "name": "--DECOD",
                    "operator": "empty"
                },
                {
                    "name": "--TRT",
                    "operator": "not_equal_to",
                    "value": "RELREC.FAOBJ"
                }
            ]
        },
        "Core": {
            "Id": "CDISC.SDTMIG.CG0602",
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "When findings are collected about an intervention, and the interventions parent record exists and --DECOD = null, FAOBJ should be equal to --TRT.",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "Interventions parent record exists and --DECOD = null, but FAOBJ is not equal to --TRT.",
            "Output_Variables": [
                "RELREC.FAOBJ",
                "--TRT",
                "--DECOD"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "INTERVENTIONS"
                ]
            },
            "Domains": {
                "Include": [
                    "ALL"
                ]
            },
            "Use_Case": "INDH"
        },
        "Sensitivity": "Record",
        "Match_Datasets": [
            {
                "Name": "RELREC",
                "Wildcard": "FA"
            }
        ],
        "Rule_Type": "Record Data"
    },
