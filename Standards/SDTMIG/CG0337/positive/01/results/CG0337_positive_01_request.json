  "rule": {
    "Authority": {
      "Organization": "CDISC"
    },
    "Check": {
      "all": [
        {
          "name": "--CAT",
          "operator": "equal_to_case_insensitive",
          "value": "--DECOD"
        }
      ]
    },
    "Citations": [
      {
        "Document": "IG v3.4",
        "Section": "4.2.6",
        "Cited_Guidance": "Values for --CAT and --SCAT should not be redundant with the domain  name or dictionary classification provided by --DECOD and --BODSYS."
      },
      {
        "Document": "IG v3.3",
        "Section": "4.2.6",
        "Cited_Guidance": "Values for --CAT and --SCAT should not be redundant with the domain  name or dictionary classification provided by --DECOD and --BODSYS."
      },
      {
        "Document": "IG v3.2",
        "Section": "4.1.2.6",
        "Cited_Guidance": "Values for --CAT and --SCAT should not be redundant with the domain  name or dictionary classification provided by --DECOD and --BODSYS."
      }
    ],
    "Core": {
      "Id": "CDISC.SDTMIG.CG0337",
      "Version": "1"
    },
    "Description": "Raise an error when --CAT = --DECOD.",
