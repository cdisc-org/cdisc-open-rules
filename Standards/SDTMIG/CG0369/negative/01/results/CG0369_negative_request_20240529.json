    "Check": {
      "all": [
        {
          "name": "RDOMAIN",
          "operator": "non_empty"
        },
        {
          "name": "RDOMAIN",
          "operator": "is_not_contained_by",
          "value": "$study_domains"
        }
      ]
    },
    "Core": {
      "Id": "CDISC.SDTMIG.CG0369",
      "Status": "Draft",
      "Version": "1"
    },
    "Description": "Raise an error when RDOMAIN is populated but the referenced RDOMAIN doesn't exist as a dataset in the present study",
    "Executability": "Fully Executable",
    "Operations": [
      {
        "id": "$study_domains",
        "operator": "study_domains"
      }
    ],
    "Outcome": {
      "Message": "RDOMAIN does not represent a dataset present in the study.",
      "Output_Variables": [
        "RDOMAIN",
        "$study_domains"
      ]
    },
    "Scope": {
      "Classes": {
        "Include": [
          "ALL"
        ]
      },
      "Domains": {
        "Include": [
          "CO",
          "RELREC",
          "SUPP--"
        ]
      }
    },
    "Sensitivity": "Dataset",
    "Rule_Type": "Record Data"
  },
