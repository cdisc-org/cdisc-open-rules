    "Check": {
      "all": [
        {
          "name": "POOLID",
          "operator": "non_empty"
        },
        {
          "name": "USUBJID",
          "operator": "non_empty"
        }
      ]
    },
    "Core": {
      "Id": "CDISC.SENDIG.132",
      "Status": "Draft",
      "Version": "1"
    },
    "Description": "Raise an error when both USUBJID and POOLID are populated",
    "Executability": "Fully Executable",
    "Outcome": {
      "Message": "When POOLID is populated, USUBJID may not be populated",
      "Output_Variables": [
        "USUBJID",
        "POOLID"
      ]
    },
    "Scope": {
      "Classes": {
        "Include": [
          "INTERVENTIONS",
          "FINDINGS"
        ]
      },
      "Domains": {
        "Include": [
          "ALL"
        ]
      }
    },
    "Sensitivity": "Record",
    "Rule_Type": "Record Data"
  },
