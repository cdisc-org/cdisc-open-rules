        "Check": {
            "all": [
                {
                    "name": "POOLID",
                    "operator": "non_empty"
                },
                {
                    "name": "POOLID",
                    "operator": "is_not_contained_by",
                    "value": "$pooldef_poolid"
                }
            ]
        },
        "Core": {
            "Id": "CDISC.SENDIG.139",
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "Part B - Raise error when value for POOLID in the dataset is not a POOLID value in POOLDEF.",
        "Executability": "Fully Executable",
        "Operations": [
            {
                "domain": "POOLDEF",
                "id": "$pooldef_poolid",
                "name": "POOLID",
                "operator": "distinct"
            }
        ],
        "Outcome": {
            "Message": "POOLID value in the dataset does not correspond to a POOLID value in POOLDEF.",
            "Output_Variables": [
                "POOLID",
                "$pooldef_poolid"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "ALL"
                ]
            },
            "Domains": {
                "Include": [
                    "ALL"
                ]
            },
            "Use_Case": "NONCLIN"
        },
        "Sensitivity": "Record",
        "Rule_Type": "Record Data"
    },
