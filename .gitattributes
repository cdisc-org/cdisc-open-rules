# Default: normalize all text files to LF in the repo
* text=auto eol=lf

# Explicitly force LF for files we own
*.csv     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.sh      text eol=lf
*.py      text eol=lf
*.md      text eol=lf
*.json    text eol=lf
*.txt     text eol=lf

# True binary files — never touch line endings
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.zip     binary
*.gz      binary
*.tar     binary
