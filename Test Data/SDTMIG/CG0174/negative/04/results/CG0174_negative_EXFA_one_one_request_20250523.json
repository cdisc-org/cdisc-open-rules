{
    "rule": {
        "Authorities": [
            {
                "Organization": "CDISC",
                "Standards": [
                    {
                        "Name": "SDTMIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "IG v3.4",
                                        "Section": "6.4.3",
                                        "Cited_Guidance": "If an FA record does have a parent record, the value in FAOBJ should match the value in --TERM or --TRT, unless the parent domain is dictionary coded or subject to controlled terminology, in which case FAOBJ should match the value in --DECOD."
                                    }
                                ],
                                "Origin": "SDTM and SDTMIG Conformance Rules",
                                "Version": "2.0",
                                "Rule_Identifier": {
                                    "Id": "CG0174",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Version": "3.4"
                    },
                    {
                        "Name": "SDTMIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "IG v3.3",
                                        "Section": "6.4.3",
                                        "Cited_Guidance": "In general, the value in FAOBJ should match the value in --TERM or --TRT, unless the parent domain is dictionary coded or subject to controlled terminology, in which case FAOBJ should then match the value in --DECOD."
                                    }
                                ],
                                "Origin": "SDTM and SDTMIG Conformance Rules",
                                "Version": "2.0",
                                "Rule_Identifier": {
                                    "Id": "CG0174",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Version": "3.3"
                    },
                    {
                        "Name": "SDTMIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "IG v3.2",
                                        "Section": "6.4.3",
                                        "Cited_Guidance": "In general, the value in FAOBJ should match the value in --TERM or --TRT, unless the parent domain is dictionary coded or subject to controlled terminology, in which case FAOBJ should then match the value in --DECOD."
                                    }
                                ],
                                "Origin": "SDTM and SDTMIG Conformance Rules",
                                "Version": "2.0",
                                "Rule_Identifier": {
                                    "Id": "CG0174",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Version": "3.2"
                    },
                    {
                        "Name": "TIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "TIG 1.0",
                                        "Section": "2.8.4",
                                        "Cited_Guidance": "A record in FA may or may not have a parent record in an events or interventions domain. If an FA record does have a parent record, the value in FAOBJ should match the value in --TERM or --TRT, unless the parent domain is dictionary coded or subject to controlled terminology. In such cases, the value represented in FAOBJ will match the value represented in --DECOD."
                                    }
                                ],
                                "Origin": "TIG Conformance Rules",
                                "Version": "1.0",
                                "Rule_Identifier": {
                                    "Id": "TIG0403",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Substandard": "SDTM",
                        "Version": "1.0"
                    }
                ]
            }
        ],
        "Check": {
            "all": [
                {
                    "name": "FAOBJ",
                    "operator": "not_equal_to",
                    "value": "RELREC.**TERM"
                },
                {
                    "name": "FAOBJ",
                    "operator": "not_equal_to",
                    "value": "RELREC.**TRT"
                },
                {
                    "name": "FAOBJ",
                    "operator": "not_equal_to_case_insensitive",
                    "value": "RELREC.**DECOD"
                }
            ]
        },
        "Core": {
            "Id": "CDISC.SDTMIG.CG0174",
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "Raise an error when a related record is present in the parent domain dataset but FAOBJ is not equal to the --TERM, --TRT or --DECOD of the parent domain.",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "Related record is present in the parent domain dataset but FAOBJ is not equal to the \"TERM\", \"TRT\" or \"DECOD\" of the parent domain.",
            "Output_Variables": [
                "FAOBJ",
                "RELREC.**TERM",
                "RELREC.**TRT",
                "RELREC.**DECOD"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "FINDINGS ABOUT"
                ]
            },
            "Domains": {
                "Include": [
                    "FA"
                ]
            },
            "Use_Case": "INDH"
        },
        "Sensitivity": "Record",
        "Match_Datasets": [
            {
                "Name": "RELREC"
            }
        ],
        "Rule_Type": "Record Data"
    },
