{
    "rule": {
        "Authorities": [
            {
                "Organization": "CDISC",
                "Standards": [
                    {
                        "Name": "SDTMIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "IG v3.4",
                                        "Section": "4.1.5",
                                        "Cited_Guidance": "When the study does not include the data item for an expected variable, however, a null column must still be included in the dataset, and a comment must be included in the Define-XML document to state that the study does not include the data item."
                                    }
                                ],
                                "Origin": "SDTM and SDTMIG Conformance Rules",
                                "Version": "2.0",
                                "Rule_Identifier": {
                                    "Id": "CG0431",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Version": "3.4"
                    },
                    {
                        "Name": "SDTMIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "IG v3.2",
                                        "Section": "4.1.1.5",
                                        "Cited_Guidance": "When no data has been collected for an expected variable; however; a null column must still be included in the dataset; and a comment must be included in the define.xml to state that data was not collected."
                                    }
                                ],
                                "Origin": "SDTM and SDTMIG Conformance Rules",
                                "Version": "2.0",
                                "Rule_Identifier": {
                                    "Id": "CG0431",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Version": "3.2"
                    },
                    {
                        "Name": "SDTMIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "IG v3.3",
                                        "Section": "4.1.5",
                                        "Cited_Guidance": "When the study does not include the data item for an expected variable; however; a null column must still be included in the dataset; and a comment must be included in the Define-XML document to state that the study does not include the data item."
                                    }
                                ],
                                "Origin": "SDTM and SDTMIG Conformance Rules",
                                "Version": "2.0",
                                "Rule_Identifier": {
                                    "Id": "CG0431",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Version": "3.3"
                    }
                ]
            }
        ],
        "Check": {
            "any": [
                {
                    "all": [
                        {
                            "metadata": "$var_exp",
                            "operator": "variable_metadata_equal_to",
                            "value": "Exp"
                        },
                        {
                            "operator": "empty"
                        }
                    ]
                }
            ]
        },
        "Core": {
            "Id": "CDISC.SDTMIG.CG0431",
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "Raise an error when variable Core Status = Expected and data is collected, but variable is not present",
        "Executability": "Fully Executable",
        "Operations": [
            {
                "id": "$var_exp",
                "name": "core",
                "operator": "variable_library_metadata"
            }
        ],
        "Outcome": {
            "Message": "Variable is empty, where variable core status is expected and data is collected.",
            "Output_Variables": [
                "$var_exp"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "ALL"
                ]
            },
            "Domains": {
                "Include": [
                    "ALL"
                ]
            }
        },
        "Sensitivity": "Record",
        "Rule_Type": "Record Data"
    },
