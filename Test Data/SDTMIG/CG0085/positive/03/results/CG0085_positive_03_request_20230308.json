{
  "rule": {
    "Check": {
      "all": [
        {
          "name": "--PRESP",
          "operator": "non_empty"
        },
        {
          "name": "--PRESP",
          "operator": "not_equal_to",
          "value": "Y"
        }
      ]
    },
    "Core": {
      "Id": "CDISC.SDTMIG.CG0085",
      "Version": "1",
      "Status": "Draft"
    },
    "Description": "Raise an error when --PRESP does not equal 'Y' or is not empty.",
    "Outcome": {
      "Message": "--PRESP does not equal 'Y' or is not empty.",
      "Output_Variables": [
        "--PRESP"
      ]
    },
    "Sensitivity": "Record",
    "Executability": "Fully Executable",
    "Authorities": [
