    "Check": {
      "all": [
        {
          "name": "SSSTRESC",
          "operator": "equal_to",
          "value": "DEAD",
          "value_is_literal": true
        },
        {
          "name": "SSDTC",
          "operator": "date_less_than",
          "value": "DTHDTC"
        }
      ]
    },
    "Core": {
      "Id": "CORE-000259",
      "Status": "Published",
      "Version": "1"
    },
    "Description": "Date time of collection of subject status in SS domain, where survival status is marked as DEAD, is on or after the date time of death populated in DM domain",
    "Executability": "Fully Executable",
    "Outcome": {
      "Message": "Date time of collection of subject status in SS domain, where survival status is marked as DEAD, is not on or after the date time of death populated in DM domain.",
      "Output_Variables": [
        "SSSTRESC",
        "SSDTC",
        "DTHDTC"
      ]
    },
    "Scope": {
      "Classes": {
        "Include": [
          "FINDINGS"
        ]
      },
      "Domains": {
        "Include": [
          "SS"
        ]
      }
    },
    "Sensitivity": "Record",
