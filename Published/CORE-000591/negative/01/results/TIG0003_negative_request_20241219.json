{
    "rule": {
        "Authorities": [
            {
                "Organization": "CDISC",
                "Standards": [
                    {
                        "Name": "TIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "TIG 1.0",
                                        "Item": "assumption 2",
                                        "Section": "2.8.8.1",
                                        "Cited_Guidance": "A minimally meaningful TO dataset must include at least the parameter for tobacco product category (TOPARMCD = TPRDCAT)"
                                    }
                                ],
                                "Origin": "TIG Conformance Rules",
                                "Version": "1.0",
                                "Rule_Identifier": {
                                    "Id": "TIG0003",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Substandard": "SDTM",
                        "Version": "1.0"
                    }
                ]
            }
        ],
        "Check": {
            "all": [
                {
                    "name": "$tbprdcat_count",
                    "operator": "equal_to",
                    "value": 0
                }
            ]
        },
        "Core": {
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "Raise an error when there is no record present in TO per SPTOBID where TOPARMCD equals TBPRDCAT.",
        "Executability": "Fully Executable",
        "Operations": [
            {
                "domain": "TO",
                "filter": {
                    "TOPARMCD": "TBPRDCAT"
                },
                "group": [
                    "SPTOBID"
                ],
                "id": "$tbprdcat_count",
                "name": "TOPARMCD",
                "operator": "record_count"
            }
        ],
        "Outcome": {
            "Message": "TO dataset does not include a record for each SPTOBID where TOPARMCD = TBPRDCAT.",
            "Output_Variables": [
                "SPTOBID",
                "$tbprdcat_count"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "STUDY REFERENCE"
                ]
            },
            "Domains": {
                "Include": [
                    "TO"
                ]
            },
            "Use_Case": "PROD"
        },
        "Sensitivity": "Record",
        "Rule_Type": "Record Data"
    },
