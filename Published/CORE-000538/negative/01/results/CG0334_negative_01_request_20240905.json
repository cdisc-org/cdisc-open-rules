                                "Origin": "SDTM and SDTMIG Conformance Rules",
                                "Version": "2.0",
                                "Rule_Identifier": {
                                    "Id": "CG0334",
                                    "Version": "2"
                                }
                            }
                        ],
                        "Version": "3.3"
                    }
