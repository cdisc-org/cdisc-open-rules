{
    "rule": {
        "Authorities": [
            {
                "Organization": "CDISC",
                "Standards": [
                    {
                        "Name": "SDTMIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "IG v3.2",
                                        "Item": "Specification",
                                        "Section": "5",
                                        "Cited_Guidance": "Values should be \"Screen Failure\" for screen failures and \"Not Assigned\" for subjects not assigned to treatment."
                                    }
                                ],
                                "Origin": "SDTM and SDTMIG Conformance Rules",
                                "Version": "2.0",
                                "Rule_Identifier": {
                                    "Id": "CG0119",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Version": "3.2"
                    }
                ]
            }
        ],
        "Check": {
            "all": [
                {
                    "name": "ACTARM",
                    "operator": "is_contained_by",
                    "value": [
                        "Screen Failure",
                        "Not Assigned"
                    ]
                },
                {
                    "name": "ACTARM",
                    "operator": "not_equal_to",
                    "value": "ARM"
                }
            ]
        },
        "Core": {
            "Id": "CDISC.SDTMIG.CG0119",
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "Raise an error when ACTARM is Screen Failure or Not Assigned, and ACTARM does not equal ARM",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "ACTARM should be equal to ARM when ACTARM is Screen Failure or Not Assigned",
            "Output_Variables": [
                "ACTARM",
                "ARM"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "SPECIAL PURPOSE"
                ]
            },
            "Domains": {
                "Include": [
                    "DM"
                ]
            }
        },
        "Sensitivity": "Record",
        "Rule_Type": "Record Data"
    },
