        "Check": {
            "all": [
                {
                    "name": "QNAM",
                    "operator": "is_contained_by",
                    "value": "$model_variables"
                }
            ]
        },
        "Core": {
            "Id": "CDISC.SDTMIG.CG0314",
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "Raise an error when SUPP--.QNAM is present in dataset, but value of SUPP--.QNAM is equal to a variable name defined in the corresponding SDTM version.",
        "Executability": "Fully Executable",
        "Operations": [
            {
                "id": "$model_variables",
                "operator": "get_parent_model_column_order"
            }
        ],
        "Outcome": {
            "Message": "SUPP--.QNAM is present in the dataset, but the value of SUPP--.QNAM equals a variable name defined in the corresponding SDTM version.",
            "Output_Variables": [
                "QNAM",
                "$model_variables"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "RELATIONSHIP"
                ]
            },
            "Domains": {
                "Include": [
                    "SUPP--"
                ]
            }
        },
        "Sensitivity": "Record",
        "Rule_Type": "Record Data"
    },
