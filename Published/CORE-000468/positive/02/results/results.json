    ],
    "Check": {
      "all": [
        {
          "name": "TSPARMCD",
          "operator": "equal_to",
          "value": "TRT"
        },
        {
          "name": "$STYPE_INTERVENTIONAL",
          "operator": "greater_than_or_equal_to",
          "value": 1
        },
        {
          "name": "TSVAL",
          "operator": "empty"
        }
      ]
    },
    "Core": {
      "Id": "CDISC.SDTMIG.CG0276",
      "Status": "Draft",
      "Version": "1"
    },
    "Description": "Raise an error when a record exists in TS where TSPARMCD = STYPE and TSVAL = INTERVENTIONAL but TSVAL for TSPARMCD = TRT is empty.",
    "Executability": "Fully Executable",
    "Operations": [
      {
        "filter": {
          "TSPARMCD": "STYPE",
          "TSVAL": "INTERVENTIONAL"
        },
        "group": [
          "TSGRPID"
        ],
        "id": "$STYPE_INTERVENTIONAL",
        "operator": "record_count"
      }
    ],
    "Outcome": {
      "Message": "A record exists in TS where TSPARMCD = STYPE and TSVAL = INTERVENTIONAL but TSVAL for TSPARMCD = TRT is empty.",
      "Output_Variables": [
        "TSGRPID",
        "TSPARMCD",
        "TSVAL",
        "$STYPE_INTERVENTIONAL"
      ]
    },
    "Scope": {
      "Classes": {
        "Include": [
          "TRIAL DESIGN"
        ]
      },
      "Domains": {
        "Include": [
          "TS"
        ]
      }
    },
    "Sensitivity": "Record",
    "Rule_Type": "Record Data"
  },
