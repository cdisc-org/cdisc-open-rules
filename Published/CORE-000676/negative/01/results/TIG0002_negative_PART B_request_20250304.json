{
    "rule": {
        "Authorities": [
            {
                "Organization": "CDISC",
                "Standards": [
                    {
                        "Name": "TIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "TIG 1.0",
                                        "Item": "assumption 1b",
                                        "Section": "2.8.8.1",
                                        "Cited_Guidance": "SPTOBID is used in the Product Design (PD), Tobacco Ingredients (IT), Non-Tobacco Ingredients (IN), and Ingredient Quantities by Component (IQ) domains, as well as any domain in the general observation classes where there are records pertaining to the tobacco product it identifies/describes (e.g., PT). Every value of SPTOBID in any dataset must correspond to a product described in the TO dataset."
                                    }
                                ],
                                "Origin": "TIG Conformance Rules",
                                "Version": "1.0",
                                "Rule_Identifier": {
                                    "Id": "TIG0002",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Substandard": "SEND",
                        "Version": "1.0"
                    }
                ]
            }
        ],
        "Check": {
            "all": [
                {
                    "name": "TXPARMCD",
                    "operator": "equal_to",
                    "value": "SPTOBID",
                    "value_is_literal": true
                },
                {
                    "name": "TXVAL",
                    "operator": "is_not_contained_by",
                    "value": "$to_sptobid"
                }
            ]
        },
        "Core": {
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "Part B - Raise an error when the value of TXVAL for TXPARMCD = SPTOBID in the TX dataset does not correspond to a SPTOBID value present in TO.",
        "Executability": "Fully Executable",
        "Operations": [
            {
                "domain": "TO",
                "id": "$to_sptobid",
                "name": "SPTOBID",
                "operator": "distinct"
            }
        ],
        "Outcome": {
            "Message": "Value in TXVAL for TXPARMCD = SPTOBID in the TX dataset does not correspond to a SPTOBID value in TO.",
            "Output_Variables": [
                "TXVAL",
                "$to_sptobid"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "TRIAL DESIGN"
                ]
            },
            "Domains": {
                "Include": [
                    "TX"
                ]
            },
            "Use_Case": "NONCLIN"
        },
        "Sensitivity": "Record",
        "Rule_Type": "Record Data"
    },
