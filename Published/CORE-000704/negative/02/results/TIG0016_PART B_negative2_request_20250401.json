{
    "rule": {
        "Authorities": [
            {
                "Organization": "CDISC",
                "Standards": [
                    {
                        "Name": "TIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "TIG 1.0",
                                        "Item": "Specification Table: PDVALTRG | PDVALMIN | PDVALMAX",
                                        "Section": "2.8.8.2",
                                        "Cited_Guidance": "No specific guidance; this is a simple mathematical definition"
                                    }
                                ],
                                "Origin": "TIG Conformance Rules",
                                "Version": "1.0",
                                "Rule_Identifier": {
                                    "Id": "TIG0016",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Substandard": "SDTM",
                        "Version": "1.0"
                    }
                ]
            }
        ],
        "Check": {
            "all": [
                {
                    "name": "--VALTRG",
                    "operator": "matches_regex",
                    "value": "^-?([1-9]\\d*|0)(\\.\\d+)?$"
                },
                {
                    "name": "--VALMAX",
                    "operator": "matches_regex",
                    "value": "^.+$"
                },
                {
                    "name": "--VALTRG",
                    "operator": "greater_than",
                    "value": "--VALMAX"
                }
            ]
        },
        "Core": {
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "Part B - Raise an error when --VALTRG is a number and is greater than the specified --VALMAX value.",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "--VALTRG is not equal to or less than the --VALMAX value.",
            "Output_Variables": [
                "SPTOBID",
                "--VALTRG",
                "--VALMAX",
                "PDPARMCD"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "SPECIAL PURPOSE"
                ]
            },
            "Domains": {
                "Include": [
                    "PD"
                ]
            },
            "Use_Case": "PROD"
        },
        "Sensitivity": "Record",
        "Rule_Type": "Record Data"
    },
