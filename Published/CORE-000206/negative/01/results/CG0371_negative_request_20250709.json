        "Core": {
            "Id": "CORE-000206",
            "Status": "Published",
            "Version": "1"
        },
        "Description": "When IDVAR is populated, IDVARVAL must equal a value of the variable referenced by IDVAR within the domain referenced by RDOMAIN",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "IDVARVAL does not equal a value of the variable referenced by IDVAR in domain = RDOMAIN.",
            "Output_Variables": [
                "RDOMAIN",
                "USUBJID",
                "IDVAR",
                "IDVARVAL"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "SPECIAL PURPOSE",
                    "RELATIONSHIP"
                ]
            },
            "Domains": {
                "Include": [
                    "CO",
                    "SUPP--",
                    "RELREC"
                ]
            },
            "Use_Case": "NONCLIN, INDH, PROD"
        },
        "Sensitivity": "Record",
        "Match_Datasets": [
            {
                "Child": true,
                "Keys": [
                    "USUBJID"
                ],
                "Name": "SUPP--",
                "Is_Relationship": true
            },
            {
