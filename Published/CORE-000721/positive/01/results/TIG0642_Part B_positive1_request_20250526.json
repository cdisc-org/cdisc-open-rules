{
    "rule": {
        "Authorities": [
            {
                "Organization": "CDISC",
                "Standards": [
                    {
                        "Name": "TIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "SDTM v2.1",
                                        "Section": "Section 3.1.4 Identifiers For All Classes",
                                        "Cited_Guidance": "STUDYID, DOMAIN, and --SEQ are required in all domains based on one of the 3 general observation classes. Each general class domain must also include at least one of the following subject identifiers - SUBJID, SPDEVID, or POOLID."
                                    },
                                    {
                                        "Document": "SDTM v2.1",
                                        "Section": "Section 4.0  Associated Persons Data",
                                        "Cited_Guidance": "The Associated Persons Identifier (APID) will be required in all AP datasets, and will identify records as AP data."
                                    }
                                ],
                                "Origin": "TIG Conformance Rules",
                                "Version": "1.0",
                                "Rule_Identifier": {
                                    "Id": "TIG0642",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Substandard": "SDTM",
                        "Version": "1.0"
                    }
                ]
            }
        ],
        "Check": {
            "all": [
                {
                    "name": "DOMAIN",
                    "operator": "exists"
                },
                {
                    "name": "STUDYID",
                    "operator": "exists"
                },
                {
                    "name": "SPTOBID",
                    "operator": "not_exists"
                }
            ]
        },
        "Core": {
            "Id": "",
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "Raise an error when STUDYID and DOMAIN exist but SPTOBID does not exist.",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "An appropriate identifier is not present; SPTOBID."
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "SPECIAL PURPOSE"
                ]
            },
            "Domains": {
                "Include": [
                    "IN",
                    "IQ",
                    "IT"
                ]
            },
            "Use_Case": "PROD"
        },
        "Sensitivity": "Dataset",
        "Rule_Type": "Record Data"
    },
