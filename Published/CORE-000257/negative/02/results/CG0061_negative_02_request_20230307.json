{
  "rule": {
    "Check": {
      "all": [
        {
          "name": "--STRTPT",
          "operator": "non_empty"
        },
        {
          "name": "--STTPT",
          "operator": "empty"
        }
      ]
    },
    "Core": {
      "Id": "CDISC.SDTMIG.CG0061",
      "Version": "1",
      "Status": "Draft"
    },
    "Description": "Raise an error when --STRTPT is completed and --STTPT is not completed.",
    "Outcome": {
      "Message": "--STRTPT is completed, but --STTPT is not completed.",
      "Output_Variables": [
        "--STRTPT",
        "--STTPT"
      ]
    },
    "Sensitivity": "Record",
    "Executability": "Fully Executable",
    "Authorities": [
      {
        "Organization": "CDISC",
        "Standards": [
          {
            "Name": "SDTMIG",
            "Version": "3.4",
            "References": [
              {
                "Origin": "SDTM and SDTMIG Conformance Rules",
                "Version": "2.0",
                "Citations": [
                  {
                    "Document": "Model v2.0",
                    "Item": "--STTPT",
                    "Section": "Timing",
                    "Cited_Guidance": "The description or date and/or time of a time point that acts as a fixed reference for characterizing the start of an observation. This is the sponsor-defined reference  point referred to by --STRTPT."
                  }
                ],
                "Rule_Identifier": {
                  "Id": "CG0061",
                  "Version": "1"
                }
              }
            ]
          },
          {
            "Name": "SDTMIG",
            "Version": "3.3",
            "References": [
              {
                "Origin": "SDTM and SDTMIG Conformance Rules",
                "Version": "2.0",
                "Citations": [
                  {
                    "Document": "Model v1.7",
                    "Item": "Table 2.2.5.1 --STTPT",
                    "Section": "2.2.5 Timing Variables for All Classes",
                    "Cited_Guidance": "Description or date/time in ISO 8601 or other character format of the sponsor-defined reference point referred to by --STRTPT. Examples; \"2003-12-15\" or \"VISIT 1\"."
                  }
                ],
                "Rule_Identifier": {
                  "Id": "CG0061",
                  "Version": "1"
                }
              }
            ]
          },
          {
            "Name": "SDTMIG",
            "Version": "3.2",
            "References": [
              {
                "Origin": "SDTM and SDTMIG Conformance Rules",
                "Version": "2.0",
                "Citations": [
                  {
                    "Document": "Model v1.4",
                    "Item": "Specification",
                    "Section": "2.2.5 Timing Variables for All Classes",
                    "Cited_Guidance": "(--STTPT) Description or date/time in ISO 8601 or other character format of the sponsor-defined reference point referred to by --STRTPT. Examples; \"2003-12-15\" or \"VISIT 1\"."
                  }
                ],
                "Rule_Identifier": {
                  "Id": "CG0061",
                  "Version": "1"
                }
              }
            ]
          }
        ]
      }
    ],
    "Scope": {
      "Classes": {
        "Include": [
          "ALL"
        ]
      },
      "Domains": {
        "Include": [
          "ALL"
        ]
      }
    },
    "Rule_Type": "Record Data"
  },
