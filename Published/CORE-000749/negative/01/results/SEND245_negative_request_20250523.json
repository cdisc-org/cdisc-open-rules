        "Check": {
            "all": [
                {
                    "name": "TSVAL",
                    "operator": "is_not_unique_set",
                    "value": "TSPARMCD"
                }
            ]
        },
        "Core": {
            "Id": "CDISC.SENDIG.245",
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "TSVAL must be unique within each distinct value of TSPARMCD",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "The value of TSVAL is not unique within the value for TSPARMCD",
            "Output_Variables": [
                "TSPARMCD",
                "TSVAL"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "TRIAL DESIGN"
                ]
            },
            "Domains": {
                "Include": [
                    "TS"
                ]
            },
            "Use_Case": "NONCLIN"
        },
        "Sensitivity": "Record",
        "Rule_Type": "Record Data"
    },
