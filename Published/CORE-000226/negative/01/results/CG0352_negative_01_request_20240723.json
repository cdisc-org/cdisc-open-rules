                        "Version": "3.2"
                    },
                    {
                        "Name": "SDTMIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "IG v3.3",
                                        "Section": "2.7",
                                        "Cited_Guidance": "The following SDTM variables; defined for use in non-clinical studies (SEND); must NEVER be used in the submission of SDTM-based data for human clinical trials: --USCHFL (Interventions; Events; Findings) --DTHREL (Findings) --EXCLFL (Findings) --REASEX (Findings) --IMPLBL (Findings) FETUSID (Identifiers) --DETECT (Timing Variables) --NOMDY (Timing Variables) --NOMLBL (Timing Variables)"
                                    }
                                ],
                                "Origin": "SDTM and SDTMIG Conformance Rules",
                                "Version": "2.0",
                                "Rule_Identifier": {
                                    "Id": "CG0352",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Version": "3.3"
                    }
                ]
            }
        ],
        "Check": {
            "all": [
                {
                    "name": "--DTHREL",
                    "operator": "exists"
                }
            ]
        },
        "Core": {
            "Id": "CORE-000226",
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "Verifying presence of SEND variable --DTHREL",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "--DTHREL must never be used in SDTM-based data for human clinical trials",
            "Output_Variables": [
                "--DTHREL"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "ALL"
                ]
            },
            "Domains": {
                "Include": [
                    "ALL"
                ]
            }
        },
