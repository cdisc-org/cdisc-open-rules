        "Check": {
            "all": [
                {
                    "name": "variable_data_type",
                    "operator": "not_equal_to",
                    "value": "library_variable_data_type"
                }
            ]
        },
        "Core": {
            "Id": "CDISC.SDTMIG.CG0012",
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "Raise an error when the variable type does not match IG Type (for domains in IG) or Model Type (custom domains)",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "Variable data type specified in the dataset does not match the variable data type in the IG or the Model.",
            "Output_Variables": [
                "variable_name",
                "variable_data_type",
                "library_variable_data_type"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "ALL"
                ]
            },
            "Domains": {
                "Include": [
                    "ALL"
                ]
            }
        },
        "Sensitivity": "Record",
        "Rule_Type": "Variable Metadata Check against Library Metadata"
    },
