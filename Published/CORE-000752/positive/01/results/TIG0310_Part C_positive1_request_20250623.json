{
    "rule": {
        "Authorities": [
            {
                "Organization": "CDISC",
                "Standards": [
                    {
                        "Name": "TIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "SDTM v2.1",
                                        "Item": "--SEQ",
                                        "Section": "3.1.4 Identifiers for All Classes",
                                        "Cited_Guidance": "A number used to uniquely identify records for a subject within a domain. The Trial Summary domain does not contain subject data, and TSSEQ is a sequence number to ensure uniqueness within the dataset."
                                    }
                                ],
                                "Origin": "TIG Conformance Rules",
                                "Version": "1.0",
                                "Rule_Identifier": {
                                    "Id": "TIG0310",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Substandard": "SDTM",
                        "Version": "1.0"
                    }
                ]
            }
        ],
        "Check": {
            "all": [
                {
                    "name": "SPTOBID",
                    "operator": "non_empty"
                },
                {
                    "name": "--SEQ",
                    "operator": "exists"
                },
                {
                    "name": "--SEQ",
                    "operator": "is_not_unique_set",
                    "value": [
                        "DOMAIN",
                        "SPTOBID"
                    ]
                }
            ]
        },
        "Core": {
            "Id": "CORE-000752",
            "Status": "Published",
            "Version": "1"
        },
        "Description": "Part C - Raise an error when --SEQ is not a unique number per one of the following identifier variables, per domain; SPTOBID.",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "--SEQ is not a unique number per SPTOBID per domain.",
            "Output_Variables": [
                "SPTOBID"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "EVENTS"
                ]
            },
            "Domains": {
                "Include": [
                    "EM"
                ]
            },
            "Use_Case": "INDH"
        },
        "Sensitivity": "Record",
        "Rule_Type": "Record Data"
    },
